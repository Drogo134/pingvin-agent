{
  "agents": {
    "defaults": {
      "timeoutSeconds": 600,
      "model": {
        "primary": "openai/gpt-4o",
        "fallbacks": ["openai/gpt-4o-mini"]
      },
      "models": {
        "openai/gpt-4o": {
          "alias": "GPT-4o (OpenAI API)",
          "agentRuntime": {
            "id": "pi"
          }
        },
        "openai/gpt-4o-mini": {
          "agentRuntime": {
            "id": "pi"
          }
        },
        "openai/*": {
          "agentRuntime": {
            "id": "pi"
          }
        }
      },
      "skills": [
        "memory",
        "crm-sbis",
        "pricing",
        "sales-intake",
        "handoff",
        "analytics",
        "email-intake",
        "followup",
        "file-check",
        "knowledge-base"
      ],
      "workspace": "/app/workspace"
    }
  },
  "skills": {
    "allowBundled": [],
    "load": {
      "watch": false
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": false
      }
    }
  },
  "commands": {
    "native": false,
    "nativeSkills": false,
    "text": true,
    "config": false,
    "plugins": false,
    "debug": false,
    "bash": true,
    "restart": false,
    "ownerAllowFrom": []
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "remote": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "timeoutSeconds": 35,
      "dmHistoryLimit": 100,
      "configWrites": false,
      "commands": {
        "native": false,
        "nativeSkills": false
      },
      "streaming": {
        "mode": "off"
      },
      "reactionLevel": "off",
      "direct": {},
      "markdown": {
        "tables": "bullets"
      }
    }
  },
  "cron": {
    "enabled": true
  }
}
