# ================================================================
# РПК ПинГвин — AI Agent Configuration
# Скопировать в .env и заполнить реальными значениями
# ================================================================

# === GATEWAY (кабинет Control UI) ===
OPENCLAW_GATEWAY_TOKEN=pingvin-mvp-dashboard-2026

# === LLM (выбор провайдера/модели в кабинете: Sessions → Model или /model) ===
# OpenAI — primary по умолчанию
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
# Если OpenAI отвечает 403 unsupported_country_region_territory — включите VPN
# и укажите локальный прокси (пример для Clash/v2rayN):
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# Anthropic — для Claude в переключателе (опционально)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_BOT_USERNAME=pingvin_rpk_bot
# Несколько менеджеров — через запятую (handoff, сводки, напоминания)
MANAGER_TELEGRAM_CHAT_IDS=1280280963,8096376287
# Один ID (опционально, если не используете CHAT_IDS)
MANAGER_TELEGRAM_CHAT_ID=

# === Saby — обращения в Контакт-центр (support-service) ===
# UI: https://online.sbis.ru/page/support-service
# API: СБИС.ЗаписатьДокумент + регламент «Обращение»
SBIS_AUTH_URL=https://online.sbis.ru/auth/service/
SBIS_API_URL=https://online.sbis.ru/service/?srv=1
SBIS_SUPPORT_URL=https://online.sbis.ru/page/support-service
SBIS_APPEAL_REGULATION_NAME=Обращение
SBIS_LOGIN=your_sbis_login
SBIS_PASSWORD=your_sbis_password
SBIS_ACCOUNT_NUMBER=
# Получатель при отправке: auto = сначала SBIS_MANAGER_ID (ИИ Агент), затем SBIS_DEPARTMENT_NAME
# Общая очередь (рекомендуется) — подразделение из Saby:
SBIS_RECIPIENT_MODE=auto
SBIS_DEPARTMENT_NAME=
SBIS_DEPARTMENT_ID=
# Или конкретный сотрудник (scripts/sbis-manager-id.md):
SBIS_MANAGER_ID=
SBIS_AUTO_SUBMIT=true
SBIS_APPEAL_DOC_TYPE=РекламацияВх
SBIS_ORG_INN=
SBIS_ORG_KPP=

# === EMAIL (Mail.ru) — можно использовать любой набор имён ===
EMAIL_USER=info@ra-pingvin.ru
EMAIL_PASSWORD=your_password
EMAIL_IMAP=imap.mail.ru
EMAIL_IMAP_HOST=imap.mail.ru
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=info@ra-pingvin.ru
EMAIL_IMAP_PASSWORD=your_password
EMAIL_SMTP_HOST=smtp.mail.ru
EMAIL_SMTP_PORT=465
COMPANY_EMAIL=info@ra-pingvin.ru
COMPANY_NAME=РПК ПинГвин

# === РАБОЧИЕ ЧАСЫ (МСК) ===
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
BUSINESS_TIMEZONE=Europe/Moscow
